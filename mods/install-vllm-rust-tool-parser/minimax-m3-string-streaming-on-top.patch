+/// Parse a MiniMax M3 opening element tag from partial streaming input.
+fn partial_open_element_tag<'i>(input: &mut MinimaxM3Input<'i>) -> ModalResult<&'i str> {
+    let name = seq!(
+        _: literal(ELEMENT_START),
+        take_until(1.., ">"),
+        _: literal(">"),
+    )
+    .parse_next(input)?;
+
+    let name = name.0;
+    if name.starts_with('/') || name.trim().is_empty() {
+        return malformed();
+    }
+    Ok(name)
