+fn parse_string_parameter_event(
+    input: &mut MinimaxM3Input<'_>,
+    parameter_name: &str,
+) -> ModalResult<MinimaxM3Event> {
+    let text = **input;
+    let close_tag = format!("{ELEMENT_END_START}{parameter_name}>");
+    if text.starts_with(&close_tag) {
+        literal(close_tag.as_str()).void().parse_next(input)?;
+        return Ok(MinimaxM3Event::StringParameterEnd);
+    }
+    if close_tag.starts_with(text) {
+        return incomplete();
+    }
