+def test_streaming_string_body_escapes_fragments_and_holds_split_close(parser):
+    body_parts = ["  leading\n", '"quoted" \\', "\x00 café 東京  trailing  "]
+    close = f"{NS}</note>"
+    results = _feed(
+        parser,
+        [
+            f"{NS}<tool_call>",
+            f'{NS}<invoke name="create_order">',
+            f"{NS}<note>",
+            *body_parts,
+            close[: len(NS) - 2],
+            close[len(NS) - 2 :],
+            f"{NS}</invoke>",
+            f"{NS}</tool_call>",
+        ],
+    )
+
+    calls = [call for result in results for call in result.tool_calls or []]
+    assert calls[0].function.name == "create_order"
+    argument_deltas = [call.function.arguments for call in calls]
+    assert argument_deltas[1] == '{"note":"'
+    assert argument_deltas[-2:] == ['"', "}"]
+    assert len(argument_deltas) >= 7
+    assert all(NS not in delta for delta in argument_deltas)
+    assert json.loads("".join(argument_deltas)) == {"note": "".join(body_parts)}
+    assert json.loads(parser.streamed_args_for_tool[0]) == {
+        "note": "".join(body_parts)
+    }
+
